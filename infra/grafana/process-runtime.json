{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping the bot /metrics endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Ghost Bot — Process & Runtime",
  "uid": "ghost-process-runtime",
  "tags": ["ghost-bot", "metrics", "runtime"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU (cores)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "rate(ghost_process_cpu_seconds_total[5m])",
          "legendFormat": "cpu",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Resident Memory (RSS)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "ghost_process_resident_memory_bytes",
          "legendFormat": "rss",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Event-loop lag (p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "ghost_event_loop_lag_seconds",
          "legendFormat": "lag",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "GC pause (rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "rate(nodejs_gc_duration_seconds_sum[5m])",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active handles",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "nodejs_active_handles_total",
          "legendFormat": "handles",
          "refId": "A"
        }
      ]
    }
  ]
}
