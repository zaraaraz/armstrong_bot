# Next.js dashboard frontend — build artifacts & generated files.
# Source (app/, lib/, middleware.ts, next.config.mjs, tsconfig.json,
# package.json, package-lock.json) IS versioned.

# dependencies
/node_modules

# next.js build output
/.next/
/out/

