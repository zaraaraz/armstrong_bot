# Discord
DISCORD_TOKEN=your_discord_token_here
DISCORD_DEV_GUILD_ID=your_dev_guild_id_here

# Database
DATABASE_URL="mysql://armstrong:armstrong@localhost:3307/armstrong_bot"
DATABASE_SHADOW_URL="mysql://root:root@localhost:3307/armstrong_bot_shadow"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App
NODE_ENV=development
HTTP_PORT=3000

# Scheduler (Phase 4 — module 13). All optional; Zod-validated defaults apply.
SCHEDULER_CONCURRENCY=8
SCHEDULER_MAX_ATTEMPTS=5
SCHEDULER_BACKOFF_MS=5000
SCHEDULER_BACKOFF_STRATEGY=exponential
SCHEDULER_RECONCILE_INTERVAL_MS=60000
SCHEDULER_DLQ=scheduler:dlq
SCHEDULER_RUN_RETENTION_DAYS=30
SCHEDULER_GLOBAL_TZ=UTC

# Event Bus
EVENT_BUS_DRIVER=in-process

# Lifecycle
SHUTDOWN_TIMEOUT_MS=15000
BOOTSTRAP_FAIL_FAST=true
HEALTH_READY_GRACE_MS=5000

# API (src/api) — secrets are ENV-only, never read from the DB
API_JWT_SECRET=change-me-to-a-32-char-minimum-secret
API_JWT_ISSUER=ghost-bot
API_JWT_TTL_SECONDS=900
API_SESSION_COOKIE=gb_session
API_SESSION_TTL_SECONDS=86400
API_SESSION_SECURE=true
API_CORS_ORIGINS=http://localhost:5173
API_RATE_WINDOW_SECONDS=60
API_RATE_ANON_MAX=30
API_RATE_USER_MAX=120
API_RATE_APIKEY_MAX=600
API_WEBHOOK_PROVIDERS=discord

# Discord OAuth (shared by API + Dashboard)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback

# Inbound webhook signing secrets (per provider, used by the signature verifier)
DISCORD_PUBLIC_KEY=your_discord_app_public_key_hex
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
FIVEM_WEBHOOK_SECRET=your_fivem_webhook_secret

# Dashboard backend (src/dashboard)
DASHBOARD_BASE_URL=http://localhost:3000
DASHBOARD_FRONTEND_ORIGIN=http://localhost:5173
DASHBOARD_OAUTH_REDIRECT_URI=http://localhost:3000/api/dashboard/auth/callback
DASHBOARD_SESSION_COOKIE=ghost_dash_sid
DASHBOARD_SESSION_TTL_SECONDS=43200
DASHBOARD_SESSION_SAMESITE=lax
DASHBOARD_SESSION_SECURE=true
DASHBOARD_TICKET_TTL_SECONDS=30
DASHBOARD_MAX_WS_PER_USER=5

# Permissions / bot identity
PERMISSION_BOT_OWNER_IDS=
BOT_GUILD_IDS=
