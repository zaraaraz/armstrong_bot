generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ─── Base: Guild & Users ───────────────────────────────────────────────────

/// A Discord guild (server). Root of all guild-scoped data.
model Guild {
  id          String    @id @default(cuid())
  discordId   String    @unique @map("discord_id") @db.VarChar(20)
  name        String    @db.VarChar(100)
  iconHash    String?   @map("icon_hash") @db.VarChar(64)
  ownerId     String    @map("owner_id") @db.VarChar(20)
  locale      String    @default("pt") @db.VarChar(10)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  config       GuildConfig?
  members      GuildMember[]
  translations Translation[]

  @@index([active])
  @@index([deletedAt])
  @@map("guilds")
}

/// Per-guild configuration blob.
model GuildConfig {
  id        String    @id @default(cuid())
  guildId   String    @unique @map("guild_id")
  prefix    String    @default("!") @db.VarChar(10)
  locale    String    @default("pt") @db.VarChar(10)
  timezone  String    @default("Europe/Lisbon") @db.VarChar(64)
  settings  Json      @default("{}")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId])
  @@index([deletedAt])
  @@map("guild_configs")
}

/// A Discord user — global, not guild-scoped.
model User {
  id         String    @id @default(cuid())
  discordId  String    @unique @map("discord_id") @db.VarChar(20)
  username   String    @db.VarChar(32)
  globalName String?   @map("global_name") @db.VarChar(32)
  avatarHash String?   @map("avatar_hash") @db.VarChar(64)
  bot        Boolean   @default(false)
  locale     String?   @db.VarChar(10)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  memberships GuildMember[]

  @@index([username])
  @@index([deletedAt])
  @@map("users")
}

/// Join entity: a User's membership in a Guild.
model GuildMember {
  id        String    @id @default(cuid())
  guildId   String    @map("guild_id")
  userId    String    @map("user_id")
  nickname  String?   @db.VarChar(32)
  roleIds   Json      @default("[]") @map("role_ids")
  joinedAt  DateTime  @map("joined_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId])
  @@index([userId])
  @@index([deletedAt])
  @@map("guild_members")
}

// ─── Core: Module Registry ────────────────────────────────────────────────

/// Persisted record of each loaded module.
model ModuleRegistration {
  id          String    @id @default(cuid())
  moduleId    String    @unique @map("module_id")
  name        String    @db.VarChar(100)
  version     String    @db.VarChar(20)
  enabled     Boolean   @default(true)
  guildScoped Boolean   @default(true) @map("guild_scoped")
  permissions Json
  emits       Json
  consumes    Json
  lastBootAt  DateTime? @map("last_boot_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  lifecycle ModuleLifecycleEvent[]

  @@index([enabled])
  @@index([moduleId])
  @@map("module_registrations")
}

/// Append-only lifecycle audit for each module.
model ModuleLifecycleEvent {
  id             String   @id @default(cuid())
  registrationId String   @map("registration_id")
  phase          String   @db.VarChar(50)
  detail         String?  @db.Text
  traceId        String   @map("trace_id") @db.VarChar(64)
  occurredAt     DateTime @default(now()) @map("occurred_at")

  registration ModuleRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([phase])
  @@index([occurredAt])
  @@map("module_lifecycle_events")
}

// ─── CI/CD: Deployment Records ────────────────────────────────────────────

/// Immutable audit record written by the deploy pipeline on each deploy.
model DeploymentRecord {
  id          String           @id @default(cuid())
  environment DeploymentEnv
  version     String           @db.VarChar(50)
  gitSha      String           @map("git_sha") @db.VarChar(40)
  imageTag    String           @map("image_tag") @db.VarChar(255)
  status      DeploymentStatus
  durationMs  Int              @map("duration_ms")
  rolledBack  Boolean          @default(false) @map("rolled_back")
  traceId     String           @map("trace_id") @db.VarChar(64)
  startedAt   DateTime         @map("started_at")
  finishedAt  DateTime?        @map("finished_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([environment, createdAt])
  @@index([version])
  @@index([gitSha])
  @@map("deployment_records")
}

enum DeploymentEnv {
  STAGING
  PRODUCTION
}

enum DeploymentStatus {
  STARTED
  SUCCEEDED
  FAILED
  ROLLED_BACK
}

// ─── i18n: Translations ───────────────────────────────────────────────────

/// A per-guild (or global) translation override authored via the dashboard.
/// File-default translations are NOT stored here — only overrides.
model Translation {
  id        String    @id @default(cuid())
  guildId   String?   @map("guild_id")
  locale    String    @db.VarChar(10)
  module    String    @db.VarChar(64)
  namespace String    @db.VarChar(64)
  key       String    @db.VarChar(255)
  value     String    @db.Text
  updatedBy String?   @map("updated_by") @db.VarChar(20)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  guild Guild? @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, locale, module, namespace, key], name: "uq_translation_scope")
  @@index([locale, module, namespace])
  @@index([guildId, locale])
  @@index([deletedAt])
  @@map("translations")
}

/// Supported locales (file defaults ∪ DB-authored).
model Locale {
  id          String    @id @default(cuid())
  code        String    @unique @db.VarChar(10)
  displayName String    @map("display_name") @db.VarChar(64)
  enabled     Boolean   @default(true)
  isDefault   Boolean   @default(false) @map("is_default")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([enabled])
  @@map("locales")
}

/// Per-user (optionally per-guild) locale preference.
model UserLocalePreference {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") @db.VarChar(20)
  guildId   String?  @map("guild_id") @db.VarChar(20)
  locale    String   @db.VarChar(10)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, guildId], name: "uq_user_guild_locale")
  @@index([userId])
  @@map("user_locale_preferences")
}

// ─── Permissions ──────────────────────────────────────────────────────────

/// A named group of claims, scoped to a guild.
model PermissionGroup {
  id        String    @id @default(cuid())
  guildId   String    @map("guild_id")
  key       String    @db.VarChar(64)
  name      String    @db.VarChar(64)
  priority  Int       @default(100)
  isSystem  Boolean   @default(false) @map("is_system")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  grants   ClaimGrant[]
  roleMaps RoleGroupMapping[]
  parents  GroupInheritance[] @relation("childGroup")
  children GroupInheritance[] @relation("parentGroup")

  @@unique([guildId, key])
  @@index([guildId])
  @@index([guildId, deletedAt])
  @@map("permission_groups")
}

/// A GRANT or DENY of a claim string on a permission group.
model ClaimGrant {
  id        String      @id @default(cuid())
  guildId   String      @map("guild_id")
  groupId   String      @map("group_id")
  claim     String      @db.VarChar(255)
  effect    ClaimEffect @default(GRANT)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  group PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, claim])
  @@index([guildId])
  @@index([guildId, claim])
  @@map("claim_grants")
}

/// Maps a Discord role to one or more permission groups.
model RoleGroupMapping {
  id            String   @id @default(cuid())
  guildId       String   @map("guild_id")
  discordRoleId String   @map("discord_role_id") @db.VarChar(20)
  groupId       String   @map("group_id")
  createdAt     DateTime @default(now()) @map("created_at")

  group PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([guildId, discordRoleId, groupId])
  @@index([guildId])
  @@index([guildId, discordRoleId])
  @@map("role_group_mappings")
}

/// Parent–child group inheritance.
model GroupInheritance {
  id            String @id @default(cuid())
  guildId       String @map("guild_id")
  childGroupId  String @map("child_group_id")
  parentGroupId String @map("parent_group_id")

  childGroup  PermissionGroup @relation("childGroup", fields: [childGroupId], references: [id], onDelete: Cascade)
  parentGroup PermissionGroup @relation("parentGroup", fields: [parentGroupId], references: [id], onDelete: Cascade)

  @@unique([childGroupId, parentGroupId])
  @@index([guildId])
  @@map("group_inheritances")
}

enum ClaimEffect {
  GRANT
  DENY
}

// ─── Events: Bus Persistence ─────────────────────────────────────────────

/// Durable log of every async/both event published through the bus.
model EventLog {
  id            String    @id @default(uuid())
  envelopeId    String    @unique @map("envelope_id")
  eventName     String    @map("event_name") @db.VarChar(128)
  guildId       String?   @map("guild_id") @db.VarChar(20)
  actorType     String    @map("actor_type") @db.VarChar(20)
  actorId       String    @map("actor_id") @db.VarChar(64)
  payload       Json
  correlationId String    @map("correlation_id") @db.VarChar(64)
  causationId   String?   @map("causation_id") @db.VarChar(64)
  version       Int       @default(1)
  delivery      String    @db.VarChar(10)
  status        String    @default("published") @db.VarChar(20)
  occurredAt    DateTime  @map("occurred_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")

  deadLetters EventDeadLetter[]

  @@index([eventName])
  @@index([guildId])
  @@index([correlationId])
  @@index([status])
  @@index([occurredAt])
  @@map("event_logs")
}

/// Dead-letter queue: envelopes whose handlers exhausted all retry attempts.
model EventDeadLetter {
  id          String    @id @default(uuid())
  envelopeId  String    @map("envelope_id") @db.VarChar(64)
  eventName   String    @map("event_name") @db.VarChar(128)
  guildId     String?   @map("guild_id") @db.VarChar(20)
  handlerId   String    @map("handler_id") @db.VarChar(128)
  payload     Json
  attempts    Int
  lastError   String    @map("last_error") @db.Text
  errorCode   String    @map("error_code") @db.VarChar(64)
  status      String    @default("pending") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at")
  replayedAt  DateTime? @map("replayed_at")
  deletedAt   DateTime? @map("deleted_at")

  eventLog EventLog? @relation(fields: [envelopeId], references: [envelopeId])

  @@index([eventName])
  @@index([handlerId])
  @@index([status])
  @@index([guildId])
  @@map("event_dead_letters")
}

// ─── Security: API Keys & Encryption ──────────────────────────────────────

/// A scoped API key. Only the Argon2id/scrypt hash is stored — never the raw key.
model ApiKey {
  id         String    @id @default(cuid())
  guildId    String?   @map("guild_id") @db.VarChar(20)
  name       String    @db.VarChar(64)
  hashedKey  String    @unique @map("hashed_key") @db.VarChar(255)
  prefix     String    @db.VarChar(16)
  scopes     String    @db.Text
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([guildId])
  @@index([prefix])
  @@map("api_keys")
}

/// Tracks master encryption keys for rotation (ACTIVE | RETIRING | RETIRED).
model EncryptionKey {
  id        String   @id @default(cuid())
  keyId     String   @unique @map("key_id") @db.VarChar(64)
  state     KeyState @default(ACTIVE)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([state])
  @@map("encryption_keys")
}

enum KeyState {
  ACTIVE
  RETIRING
  RETIRED
}

// ─── Plugin System ────────────────────────────────────────────────────────

/// A plugin installed in the host.
model Plugin {
  id          String       @id @default(cuid())
  name        String       @unique @db.VarChar(128)
  displayName String       @map("display_name") @db.VarChar(128)
  version     String       @db.VarChar(32)
  author      String       @db.VarChar(128)
  scope       PluginScope  @default(GUILD)
  status      PluginStatus @default(INSTALLED)
  sdkRange    String       @map("sdk_range") @db.VarChar(64)
  checksum    String?      @db.VarChar(64)
  manifest    Json
  installedAt DateTime     @default(now()) @map("installed_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  enablements PluginEnablement[]
  configs     PluginConfig[]
  versions    PluginVersionHistory[]

  @@index([name])
  @@index([status])
  @@index([scope])
  @@index([deletedAt])
  @@map("plugins")
}

/// Per-guild (or global) enablement state for a plugin.
model PluginEnablement {
  id        String    @id @default(cuid())
  pluginId  String    @map("plugin_id")
  guildId   String?   @map("guild_id") @db.VarChar(20)
  enabled   Boolean   @default(true)
  enabledBy String    @map("enabled_by") @db.VarChar(20)
  enabledAt DateTime  @default(now()) @map("enabled_at")
  deletedAt DateTime? @map("deleted_at")

  plugin Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([pluginId, guildId])
  @@index([guildId])
  @@index([pluginId])
  @@map("plugin_enablements")
}

/// Per-plugin, per-guild (or global) configuration blob.
model PluginConfig {
  id        String    @id @default(cuid())
  pluginId  String    @map("plugin_id")
  guildId   String?   @map("guild_id") @db.VarChar(20)
  values    Json
  updatedAt DateTime  @updatedAt @map("updated_at")

  plugin Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([pluginId, guildId])
  @@index([pluginId])
  @@map("plugin_configs")
}

/// Immutable record of every version change for a plugin.
model PluginVersionHistory {
  id          String    @id @default(cuid())
  pluginId    String    @map("plugin_id")
  fromVersion String?   @map("from_version") @db.VarChar(32)
  toVersion   String    @map("to_version") @db.VarChar(32)
  actorId     String    @map("actor_id") @db.VarChar(20)
  appliedAt   DateTime  @default(now()) @map("applied_at")

  plugin Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@index([pluginId])
  @@map("plugin_version_histories")
}

enum PluginScope {
  GUILD
  GLOBAL
}

enum PluginStatus {
  INSTALLED
  ENABLED
  DISABLED
  ERRORED
  UPDATING
  REMOVED
}

// ─── Testing: CI Telemetry ────────────────────────────────────────────────

/// Optional CI/test telemetry — records suite outcomes per commit (guild-agnostic).
model TestRun {
  id               String     @id @default(cuid())
  commitSha        String     @map("commit_sha") @db.VarChar(40)
  branch           String     @db.VarChar(255)
  suite            TestSuite
  passed           Int
  failed           Int
  skipped          Int        @default(0)
  durationMs       Int        @map("duration_ms")
  coverageLines    Decimal?   @map("coverage_lines") @db.Decimal(5, 2)
  coverageBranches Decimal?   @map("coverage_branches") @db.Decimal(5, 2)
  createdAt        DateTime   @default(now()) @map("created_at")
  deletedAt        DateTime?  @map("deleted_at")

  @@index([commitSha])
  @@index([branch, createdAt])
  @@index([suite, createdAt])
  @@map("test_runs")
}

enum TestSuite {
  UNIT
  INTEGRATION
  CONTRACT
  E2E
}

// ─── API: Webhook Deliveries ──────────────────────────────────────────────

/// Durable audit trail of every inbound webhook accepted at the API boundary.
/// Verified payloads are persisted, enqueued for processing, and pruned by a
/// scheduled job past the configured retention.
model WebhookDelivery {
  id          String    @id @default(cuid())
  provider    String    @db.VarChar(16) // discord | github | stripe | fivem
  eventType   String    @map("event_type") @db.VarChar(128)
  guildId     String?   @map("guild_id") @db.VarChar(20)
  signature   String?   @db.VarChar(512)
  status      String    @default("received") @db.VarChar(20) // received | processed | failed
  attempts    Int       @default(0)
  payload     Json
  error       String?   @db.Text
  requestId   String    @map("request_id") @db.VarChar(64)
  receivedAt  DateTime  @default(now()) @map("received_at")
  processedAt DateTime? @map("processed_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([provider, eventType])
  @@index([guildId])
  @@index([status])
  @@index([requestId])
  @@map("webhook_deliveries")
}

// ─── Dashboard ────────────────────────────────────────────────────────────

/// Durable record of a dashboard login session (hot copy lives in Cache).
/// The Discord refresh token is encrypted at rest. Soft-revoked via revokedAt.
model DashboardSession {
  id           String    @id @default(cuid())
  discordId    String    @map("discord_id") @db.VarChar(20)
  username     String    @db.VarChar(32)
  refreshToken String    @map("refresh_token") @db.Text // AES-256-GCM ciphertext
  createdAt    DateTime  @default(now()) @map("created_at")
  lastSeenAt   DateTime  @default(now()) @map("last_seen_at")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")

  @@index([discordId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("dashboard_sessions")
}

/// A backup job triggered from the dashboard. Status tracks the BullMQ job.
model Backup {
  id          String    @id @default(cuid())
  guildId     String    @map("guild_id") @db.VarChar(20)
  status      String    @default("pending") @db.VarChar(20) // pending | running | completed | failed
  jobId       String?   @map("job_id") @db.VarChar(64)
  sizeBytes   BigInt?   @map("size_bytes")
  storageKey  String?   @map("storage_key") @db.VarChar(512)
  error       String?   @db.Text
  requestedBy String    @map("requested_by") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([guildId, status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("dashboard_backups")
}

/// Append-only audit entry written for every dashboard write action.
model DashboardAuditEntry {
  id        String   @id @default(cuid())
  guildId   String   @map("guild_id") @db.VarChar(20)
  actorId   String   @map("actor_id") @db.VarChar(20)
  action    String   @db.VarChar(64) // e.g. module.toggle, config.update, apikey.create
  target    String?  @db.VarChar(255)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([guildId, createdAt])
  @@index([actorId])
  @@map("dashboard_audit_entries")
}

// ─── Cache: Settings ──────────────────────────────────────────────────────

/// Optional per-guild (or global) cache overrides.
model CacheSetting {
  id            String    @id @default(cuid())
  guildId       String?   @map("guild_id")
  ttlMultiplier Float     @default(1) @map("ttl_multiplier")
  disabled      Boolean   @default(false)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  @@unique([guildId])
  @@index([guildId])
  @@index([deletedAt])
  @@map("cache_settings")
}

// ─── Scheduler: Durable Jobs ──────────────────────────────────────────────

enum ScheduleStatus {
  pending
  active
  paused
  completed
  cancelled
  failed
}

enum ScheduleType {
  once
  recurring
}

/// A durable schedule definition. The Scheduler module re-hydrates these into
/// BullMQ on boot via the reconciler. `guildId` null => global/system job.
model Schedule {
  id             String         @id @default(cuid())
  guildId        String?        @map("guild_id")
  kind           String
  type           ScheduleType
  status         ScheduleStatus @default(pending)
  payload        Json
  idempotencyKey String?        @map("idempotency_key")
  cron           String?
  everyMs        Int?           @map("every_ms")
  timezone       String         @default("UTC")
  nextRunAt      DateTime?      @map("next_run_at")
  lastRunAt      DateTime?      @map("last_run_at")
  deferrable     Boolean        @default(true)
  maxAttempts    Int            @default(5) @map("max_attempts")
  bullJobId      String?        @map("bull_job_id")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  runs ScheduleRun[]

  @@unique([guildId, kind, idempotencyKey], name: "schedule_dedup")
  @@index([guildId, status])
  @@index([kind, status])
  @@index([nextRunAt])
  @@index([deletedAt])
  @@map("schedules")
}

/// One execution attempt of a Schedule. Purged after `runRetentionDays`.
model ScheduleRun {
  id         String         @id @default(cuid())
  scheduleId String         @map("schedule_id")
  schedule   Schedule       @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  guildId    String?        @map("guild_id")
  attempt    Int            @default(1)
  status     ScheduleStatus
  startedAt  DateTime       @default(now()) @map("started_at")
  finishedAt DateTime?      @map("finished_at")
  durationMs Int?           @map("duration_ms")
  error      String?        @db.Text
  traceId    String?        @map("trace_id")

  @@index([scheduleId, startedAt])
  @@index([guildId, status])
  @@map("schedule_runs")
}
